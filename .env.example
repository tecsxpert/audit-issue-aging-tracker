GROQ_API_KEY=your_groq_api_key_here
APP_ENV=development
DEPLOYMENT_ENV=development
LOG_LEVEL=INFO
RELEASE_VERSION=local
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
RATE_LIMIT=30 per minute
REDIS_URL=redis://localhost:6379/0
JWT_AUTH_ENABLED=true
JWT_SECRET=replace_with_a_32_character_minimum_secret
JWT_ALGORITHM=HS256
JWT_AUDIENCE=tool-125
JWT_ISSUER=tool-125-auth
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
REQUEST_TIMEOUT_SECONDS=10
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=900
GROQ_MAX_RETRIES=3
GROQ_BACKOFF_SECONDS=1.0
GROQ_TIMEOUT_SECONDS=10
AI_TASK_QUEUE_ENABLED=true
AI_TASK_QUEUE_NAME=tool125:task-queue:ai
AI_TASK_RESULT_TTL_SECONDS=3600
AI_TASK_MAX_ATTEMPTS=3
AI_WORKER_CONCURRENCY=2
AI_WORKER_POLL_TIMEOUT_SECONDS=5
AI_WORKER_HEARTBEAT_TTL_SECONDS=30
POSTGRES_DB=tool125
POSTGRES_USER=tool125
POSTGRES_PASSWORD=tool125_dev_password
