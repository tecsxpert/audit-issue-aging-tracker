APP_ENV=production
DEPLOYMENT_ENV=production
LOG_LEVEL=INFO
RELEASE_VERSION=replace_with_release_tag
GROQ_API_KEY=inject_from_secret_manager
JWT_SECRET=inject_from_secret_manager_minimum_32_chars
POSTGRES_PASSWORD=inject_from_secret_manager
RATE_LIMIT=60 per minute
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=900
AI_TASK_RESULT_TTL_SECONDS=3600
